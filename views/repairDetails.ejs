<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Repair Details - Repair Master</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/sidebar', { user: user, pageTitle: 'Repair Details', currentPage: 'repairs' }) %>

    <h2 class="mb-4">Repair Details</h2>

    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-success">
        <% messages.forEach(function(message) { %>
          <p class="mb-0"><%= message %></p>
        <% }); %>
      </div>
    <% } %>

    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <% errors.forEach(function(error) { %>
          <p class="mb-0"><%= error %></p>
        <% }); %>
      </div>
    <% } %>

    <div class="card mb-4">
      <div class="card-body">
        <p><strong>Repair ID:</strong> <%= repair.repair_id %></p>
        <p><strong>Client Name:</strong> <%= repair.client_name %></p>
        <p><strong>Client Email:</strong> <%= repair.client_email %></p>
        <p><strong>Laptop Brand:</strong> <%= repair.laptop_brand %></p>
        <p><strong>Laptop Model:</strong> <%= repair.laptop_model %></p>
        <p><strong>Serial Number:</strong> <%= repair.serial_number || '-' %></p>
        <p><strong>Issue Description:</strong> <%= repair.issue_description %></p>
        <p><strong>Status:</strong> <%= repair.status %></p>
        <p><strong>Storage Location:</strong> <%= repair.storage_location || '-' %></p>
        <p><strong>Created At:</strong> <%= repair.created_at ? new Date(repair.created_at).toLocaleString() : '-' %></p>
        <p><strong>Updated At:</strong> <%= repair.updated_at ? new Date(repair.updated_at).toLocaleString() : '-' %></p>
      </div>
    </div>

    <h4>Repair Notes</h4>
    <% if (!notes || notes.length === 0) { %>
      <p>No notes yet.</p>
    <% } else { %>
      <ul class="list-group mb-4">
        <% notes.forEach(function(note) { %>
          <li class="list-group-item">
            <strong>Status:</strong> <%= note.status_at_time %><br>
            <strong>Note:</strong> <%= note.note_text %><br>
            <small>By <%= note.full_name %> on <%= note.created_at ? new Date(note.created_at).toLocaleString() : '-' %></small>
          </li>
        <% }) %>
      </ul>
    <% } %>

    <h4>Status History</h4>
    <% if (!history || history.length === 0) { %>
      <p>No history yet.</p>
    <% } else { %>
      <ul class="list-group mb-4">
        <% history.forEach(function(item) { %>
          <li class="list-group-item">
            <strong>From:</strong> <%= item.old_status || 'None' %>
            → <strong>To:</strong> <%= item.new_status %><br>
            <strong>Note:</strong> <%= item.change_note || '-' %><br>
            <small>By <%= item.full_name %> on <%= item.changed_at ? new Date(item.changed_at).toLocaleString() : '-' %></small>
          </li>
        <% }) %>
      </ul>
    <% } %>

    <a href="/repairs" class="btn btn-secondary">Back to Repairs</a>

    <% if (user && (user.role === 'admin' || user.role === 'engineer')) { %>
      <a href="/repairs/edit/<%= repair.id %>" class="btn btn-primary">Edit Repair</a>
    <% } %>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>