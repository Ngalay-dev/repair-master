<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Repair Master Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/sidebar', { user: user, pageTitle: 'Dashboard', currentPage: 'dashboard' }) %>

    <h2 class="mb-3">Dashboard</h2>

    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-success">
        <% messages.forEach(function(message) { %>
          <p class="mb-0"><%= message %></p>
        <% }); %>
      </div>
    <% } %>

    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <% errors.forEach(function(error) { %>
          <p class="mb-0"><%= error %></p>
        <% }); %>
      </div>
    <% } %>

    <p>
      Welcome,
      <strong><%= user ? user.full_name : 'User' %></strong>
      <% if (user) { %>
        (<%= user.role %>)
      <% } %>
    </p>

    <div class="row mt-4">
      <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <h5>Total Repairs</h5>
            <h2><%= totalRepairs %></h2>
          </div>
        </div>
      </div>

      <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <h5>Waiting for Approval</h5>
            <h2><%= waitingCount %></h2>
          </div>
        </div>
      </div>

      <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <h5>In Progress</h5>
            <h2><%= progressCount %></h2>
          </div>
        </div>
      </div>

      <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <h5>Finished</h5>
            <h2><%= finishedCount %></h2>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-4 d-flex flex-wrap gap-2">
      <a href="/repairs" class="btn btn-primary">View All Repairs</a>

      <% if (user && (user.role === 'admin' || user.role === 'engineer')) { %>
        <a href="/repairs/add" class="btn btn-success">Add Repair</a>
      <% } %>

      <a href="/repairs/search" class="btn btn-outline-primary">Search Repair ID</a>
    </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>