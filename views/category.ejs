<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Search Repair ID - Repair Master</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/sidebar', { user: user, pageTitle: 'Search Repair', currentPage: 'search' }) %>

    <h2 class="mb-4">Search Repair by Repair ID</h2>

    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-success">
        <% messages.forEach(function(message) { %>
          <p class="mb-0"><%= message %></p>
        <% }); %>
      </div>
    <% } %>

    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <% errors.forEach(function(error) { %>
          <p class="mb-0"><%= error %></p>
        <% }); %>
      </div>
    <% } %>

    <form action="/repairs/search" method="POST" class="mb-4">
      <div class="mb-3">
        <label for="repair_id" class="form-label">Repair ID</label>
        <input
          type="text"
          id="repair_id"
          name="repair_id"
          class="form-control"
          placeholder="Example: REP-0001"
          required
        >
      </div>
      <button type="submit" class="btn btn-primary">Search</button>
    </form>

    <% if (repair) { %>
      <div class="card shadow-sm">
        <div class="card-body">
          <p><strong>Repair ID:</strong> <%= repair.repair_id %></p>
          <p><strong>Client Name:</strong> <%= repair.client_name %></p>
          <p><strong>Client Email:</strong> <%= repair.client_email %></p>
          <p><strong>Laptop:</strong> <%= repair.laptop_brand %> <%= repair.laptop_model %></p>
          <p><strong>Status:</strong> <%= repair.status %></p>
          <p><strong>Storage Location:</strong> <%= repair.storage_location || '-' %></p>
          <p><strong>Device Loan:</strong> <%= repair.device_loan || '-' %></p>
          <a href="/repairs/<%= repair.id %>" class="btn btn-success">View Full Details</a>
        </div>
      </div>
    <% } %>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>