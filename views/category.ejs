<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Search Repair ID - Mac Repair App</title>
</head>
<body>
  <%- include('views/partials/navbar', { user: user }) %>

  <div class="container mt-4" style="max-width: 700px;">
    <h2 class="mb-4">Search Repair by Repair ID</h2>

    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <% errors.forEach(function(error) { %>
          <p class="mb-0"><%= error %></p>
        <% }); %>
      </div>
    <% } %>

    <form action="/repairs/search" method="POST" class="mb-4">
      <div class="mb-3">
        <label class="form-label">Repair ID</label>
        <input type="text" name="repair_id" class="form-control" placeholder="Example: REP-0001" required>
      </div>
      <button type="submit" class="btn btn-primary">Search</button>
    </form>

    <% if (repair) { %>
      <div class="card">
        <div class="card-body">
          <p><strong>Repair ID:</strong> <%= repair.repair_id %></p>
          <p><strong>Client Name:</strong> <%= repair.client_name %></p>
          <p><strong>Client Email:</strong> <%= repair.client_email %></p>
          <p><strong>Laptop:</strong> <%= repair.laptop_brand %> <%= repair.laptop_model %></p>
          <p><strong>Status:</strong> <%= repair.status %></p>
          <p><strong>Storage Location:</strong> <%= repair.storage_location || '-' %></p>
          <a href="/repairs/<%= repair.id %>" class="btn btn-success">View Full Details</a>
        </div>
      </div>
    <% } %>
  </div>
</body>
</html>