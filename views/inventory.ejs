<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Repairs - Mac Repair App</title>
</head>
<body>
  <%- include('navbar', { user: user }) %>

  <div class="container mt-4">
    <h2 class="mb-3">Repair Records</h2>
    <p>Welcome, <strong><%= user.full_name %></strong> (<%= user.role %>)</p>

    <table class="table table-bordered table-hover text-center align-middle">
      <thead class="table-dark">
        <tr>
          <th>Repair ID</th>
          <th>Client Name</th>
          <th>Laptop Model</th>
          <th>Status</th>
          <th>Storage Location</th>
          <th>Updated At</th>
          <th>View</th>
          <% if (user.role === 'admin' || user.role === 'engineer') { %>
            <th>Edit</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% if (repairs.length === 0) { %>
          <tr>
            <td colspan="<%= (user.role === 'admin' || user.role === 'engineer') ? 7 : 6 %>">No repair records found.</td>
          </tr>
        <% } %>

        <% repairs.forEach(repair => { %>
          <tr>
            <td><%= repair.repair_id %></td>
            <td><%= repair.client_name %></td>
            <td><%= repair.laptop_brand %> <%= repair.laptop_model %></td>
            <td><%= repair.status %></td>
            <td><%= repair.storage_location || '-' %></td>
            <td><%= repair.updated_at %></td>
            <td>
              <a href="/repairs/<%= repair.id %>" class="btn btn-sm btn-primary">View</a>
            </td>
            <% if (user.role === 'admin' || user.role === 'engineer') { %>
              <td>
                <a href="/repairs/edit/<%= repair.id %>" class="btn btn-sm btn-warning">Edit</a>
              </td>
            <% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</body>
</html>