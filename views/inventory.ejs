<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Repair Records - Repair Master</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/sidebar', { user: user, pageTitle: 'Repair Records', currentPage: 'repairs' }) %>

    <h2 class="mb-3">Repair Records</h2>

    <p>
      Welcome,
      <strong><%= user ? user.full_name : 'User' %></strong>
      <% if (user) { %>
        (<%= user.role %>)
      <% } %>
    </p>

    <% if (messages && messages.length > 0) { %>
      <div class="alert alert-success">
        <% messages.forEach(function(message) { %>
          <p class="mb-0"><%= message %></p>
        <% }); %>
      </div>
    <% } %>

    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <% errors.forEach(function(error) { %>
          <p class="mb-0"><%= error %></p>
        <% }); %>
      </div>
    <% } %>

    <div class="table-responsive">
      <table class="table table-bordered table-hover text-center align-middle">
        <thead class="table-dark">
          <tr>
            <th>Repair ID</th>
            <th>Client Name</th>
            <th>Laptop Model</th>
            <th>Status</th>
            <th>Storage Location</th>
            <th>Updated At</th>
            <th>View</th>
            <% if (user && (user.role === 'admin' || user.role === 'engineer')) { %>
              <th>Edit</th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% if (!repairs || repairs.length === 0) { %>
            <tr>
              <td colspan="<%= (user && (user.role === 'admin' || user.role === 'engineer')) ? 8 : 7 %>">
                No repair records found.
              </td>
            </tr>
          <% } %>

          <% if (repairs && repairs.length > 0) { %>
            <% repairs.forEach(function(repair) { %>
              <tr>
                <td><%= repair.repair_id %></td>
                <td><%= repair.client_name %></td>
                <td><%= repair.laptop_brand %> <%= repair.laptop_model %></td>
                <td><%= repair.status %></td>
                <td><%= repair.storage_location || '-' %></td>
                <td>
                  <%= repair.updated_at ? new Date(repair.updated_at).toLocaleString() : '-' %>
                </td>
                <td>
                  <a href="/repairs/<%= repair.id %>" class="btn btn-sm btn-primary">View</a>
                </td>
                <% if (user && (user.role === 'admin' || user.role === 'engineer')) { %>
                  <td>
                    <a href="/repairs/edit/<%= repair.id %>" class="btn btn-sm btn-warning">Edit</a>
                  </td>
                <% } %>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>